[Desktop Entry]
Name=Cosmic Pomodoro
Comment=Simple Pomodoro applet for Cosmic Desktop
Type=Application
Icon=io.github.petar030.cosmic-pomodoro
Exec=cosmic-pomodoro %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
